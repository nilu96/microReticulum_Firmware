[Unit]
Description=RNode Daemon Service
After=network-online.target
StartLimitInterval=200
StartLimitBurst=5

[Service]
AmbientCapabilities=CAP_NET_BIND_SERVICE
User=rnoded
Group=rnoded
Type=simple
ExecStart=/usr/bin/rnoded
#WorkingDirectory=./
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

